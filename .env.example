# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SUPABASE_CONNECTION_STRING: Your real Supabase PostgreSQL connection string (with Session/Transaction Pooler key)
# Configure this in the Secrets Panel in AI Studio
SUPABASE_CONNECTION_STRING=postgresql://postgres.placeholder:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

